<script>
  const ws = new WebSocket('ws://' + location.host);
  const consoleEl = document.getElementById('console');

  function addLog(text, kind) {
    const line = document.createElement('div');
    line.className = 'log-line ' + (kind || 'info');
    line.textContent = text;
    consoleEl.appendChild(line);
    consoleEl.scrollTop = consoleEl.scrollHeight;
  }

  ws.onopen = () => addLog('Connected to dashboard server.', 'info');
  ws.onclose = () => addLog('Dashboard server connection lost.', 'info');
  ws.onmessage = (event) => {
    const msg = JSON.parse(event.data);
    if (msg.type === 'state') updateState(msg.state);
    if (msg.type === 'log') addLog(msg.text, msg.kind || 'info');
  };

  function sendCommand(cmd, args) {
    args = args || [];
    ws.send(JSON.stringify({ type: 'command', cmd: cmd, args: args }));
    addLog('$ ' + cmd + (args.length ? ' ' + args.join(' ') : ''), 'cmd');
  }

  document.querySelectorAll('[data-cmd]').forEach(btn => {
    btn.addEventListener('click', () => sendCommand(btn.dataset.cmd));
  });

  document.getElementById('gotoBtn').addEventListener('click', () => {
    const x = document.getElementById('gotoX').value;
    const y = document.getElementById('gotoY').value;
    const z = document.getElementById('gotoZ').value;
    if (x === '' || y === '' || z === '') return;
    sendCommand('goto', [x, y, z]);
  });

  document.getElementById('chatBtn').addEventListener('click', sendChat);
  document.getElementById('chatInput').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') sendChat();
  });
  function sendChat() {
    const input = document.getElementById('chatInput');
    if (!input.value.trim()) return;
    sendCommand('say', [input.value.trim()]);
    input.value = '';
  }

  function updateState(state) {
    const pill = document.getElementById('connPill');
    if (state.connected) {
      pill.textContent = '● ONLINE';
      pill.className = 'conn-pill online';
      document.getElementById('botname').textContent = state.username + ' — ' + (state.dimension || 'overworld');

      const h = Math.max(0, Math.min(20, state.health || 0));
      const f = Math.max(0, Math.min(20, state.food || 0));
      document.getElementById('healthVal').textContent = h + '/20';
      document.getElementById('healthBar').style.width = (h / 20 * 100) + '%';
      document.getElementById('foodVal').textContent = f + '/20';
      document.getElementById('foodBar').style.width = (f / 20 * 100) + '%';

      if (state.position) {
        document.getElementById('coordX').textContent = Math.floor(state.position.x);
        document.getElementById('coordY').textContent = Math.floor(state.position.y);
        document.getElementById('coordZ').textContent = Math.floor(state.position.z);
      }

      const playersList = document.getElementById('playersList');
      const others = (state.players || []).filter(p => p !== state.username);
      playersList.innerHTML = others.length ? others.map(p => '<span>' + p + '</span>').join('') : 'none nearby';

      const invList = document.getElementById('invList');
      invList.innerHTML = (state.inventory && state.inventory.length)
        ? state.inventory.map(i => '<span>' + i.name + ' ×' + i.count + '</span>').join('')
        : 'empty';

    } else {
      pill.textContent = '● OFFLINE';
      pill.className = 'conn-pill offline';
      document.getElementById('botname').textContent = 'not connected';
    }
  }
</script>
</body>
</html>`;

