/**
 * mincraf 1.js
 * ───────────────────────────────────────────────────────────
 * Fully customizable Minecraft AI Bot — single file edition.
 * Includes: bot logic, web control panel, and dashboard server,
 * all in one file. Edit the CONFIG object below to customize.
 *
 * Setup:
 *   npm install mineflayer mineflayer-pathfinder ws
 *   node "mincraf 1.js"
 *   open http://localhost:3000
 * ───────────────────────────────────────────────────────────
 */

// ════════════════════════════════════════════════════════════
//  CONFIG — edit this to customize your bot
// ════════════════════════════════════════════════════════════
const CONFIG = {
  bot: {
    username: "YourBotName",
    password: "",
    auth: "microsoft",          // "microsoft" | "mojang" | "offline"
    owner: "YourMinecraftUsername",
    ownerOnly: true,
    commandPrefix: "!",
  },

  server: {
    host: "localhost",
    port: 25565,
    version: "1.20.1",          // or false to auto-detect
  },

  autoReconnect: true,
  maxReconnectAttempts: 5,
  reconnectDelay: 5,            // seconds

  dashboard: {
    port: 3000,
  },

  behaviors: {
    greeting: "Hello! I'm online and ready.",
    deathMessage: "I died... respawning!",
    lowHealthThreshold: 5,
    lowHealthMessage: "I'm almost dead, help!",
    antiAfk: true,
    antiAfkInterval: 30000,
    autoLook: false,
    autoRespond: {
      "hello": "Hey there!",
      "bye": "Goodbye!",
      "how are you": "I'm doing great, thanks for asking!",
    },
  },
};

// ════════════════════════════════════════════════════════════
//  DEPENDENCIES
// ════════════════════════════════════════════════════════════
const mineflayer = require('mineflayer');
const { pathfinder, Movements, goals } = require('mineflayer-pathfinder');
const http = require('http');
const { WebSocketServer } = require('ws');

let bot;
let reconnectAttempts = 0;
let statePushInterval;
const MAX_RECONNECT = CONFIG.autoReconnect ? (CONFIG.maxReconnectAttempts || 5) : 0;

// ════════════════════════════════════════════════════════════
//  DASHBOARD SERVER (web control panel + WebSocket bridge)
// ════════════════════════════════════════════════════════════
let wsClients = new Set();

function startDashboard(port) {
  const server = http.createServer((req, res) => {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(DASHBOARD_HTML);
  });

  const wss = new WebSocketServer({ server });

  wss.on('connection', (ws) => {
    wsClients.add(ws);
    ws.on('message', (raw) => {
      try {
        const msg = JSON.parse(raw.toString());
        if (msg.type === 'command') {
          const result = runCommand(msg.cmd, msg.args || []);
          ws.send(JSON.stringify({ type: 'log', text: `> ${result}` }));
        }
      } catch (e) { /* ignore malformed */ }
    });
    ws.on('close', () => wsClients.delete(ws));
  });

  server.listen(port, () => {
    console.log(`\n🖥️   Dashboard running at http://localhost:${port}\n`);
  });
}

function broadcastState(state) {
  const payload = JSON.stringify({ type: 'state', state });
  for (const ws of wsClients) if (ws.readyState === ws.OPEN) ws.send(payload);
}

function broadcastLog(text, kind = 'info') {
  const payload = JSON.stringify({ type: 'log', text, kind });
  for (const ws of wsClients) if (ws.readyState === ws.OPEN) ws.send(payload);
}

// ════════════════════════════════════════════════════════════
//  LOGGING + STATE
// ════════════════════════════════════════════════════════════
function log(msg) {
  const ts = new Date().toLocaleTimeString();
  console.log(`[${ts}] ${msg}`);
  broadcastLog(`[${ts}] ${msg}`);
}

function pushState() {
  if (!bot || !bot.entity) {
    broadcastState({ connected: false });
    return;
  }
  broadcastState({
    connected: true,
    username: bot.username,
    health: bot.health,
    food: bot.food,
    position: bot.entity.position,
    dimension: bot.game?.dimension,
    time: bot.time?.timeOfDay,
    players: Object.keys(bot.players),
    inventory: bot.inventory.items().map(i => ({ name: i.name, count: i.count })),
  });
}

// ════════════════════════════════════════════════════════════
//  BOT
// ════════════════════════════════════════════════════════════
function createBot() {
  log(`Connecting to ${CONFIG.server.host}:${CONFIG.server.port} as ${CONFIG.bot.username}...`);

  bot = mineflayer.createBot({
    host:     CONFIG.server.host,
    port:     CONFIG.server.port,
    username: CONFIG.bot.username,
    password: CONFIG.bot.password || undefined,
    version:  CONFIG.server.version || false,
    auth:     CONFIG.bot.auth || 'mojang',
  });

  bot.loadPlugin(pathfinder);

  bot.once('spawn', () => {
    reconnectAttempts = 0;
    log(`✅ Spawned in world as ${bot.username}`);

    bot.pathfinder.setMovements(new Movements(bot));

    if (CONFIG.behaviors.greeting) {
      setTimeout(() => bot.chat(CONFIG.behaviors.greeting), 1500);
    }
    if (CONFIG.behaviors.autoLook) startAutoLook();
    if (CONFIG.behaviors.antiAfk) startAntiAfk();

    pushState();
    clearInterval(statePushInterval);
    statePushInterval = setInterval(pushState, 1000);
  });

  bot.on('chat', (username, message) => {
    if (username === bot.username) return;
    log(`[CHAT] ${username}: ${message}`);
    broadcastLog(`💬 ${username}: ${message}`, 'chat');
    handleChat(username, message);
  });

  bot.on('health', () => {
    pushState();
    if (bot.health <= CONFIG.behaviors.lowHealthThreshold && CONFIG.behaviors.lowHealthMessage) {
      bot.chat(CONFIG.behaviors.lowHealthMessage);
    }
  });

  bot.on('death', () => {
    log('💀 Bot died.');
    pushState();
    if (CONFIG.behaviors.deathMessage) bot.chat(CONFIG.behaviors.deathMessage);
  });

  bot.on('kicked', (reason) => {
    log(`⚠️  Kicked: ${reason}`);
    clearInterval(statePushInterval);
    broadcastState({ connected: false });
    tryReconnect();
  });

  bot.on('error', (err) => log(`❌ Error: ${err.message}`));

  bot.on('end', () => {
    log('🔌 Disconnected.');
    clearInterval(statePushInterval);
    broadcastState({ connected: false });
    tryReconnect();
  });

  let antiAfkInterval;
  function startAntiAfk() {
    clearInterval(antiAfkInterval);
    antiAfkInterval = setInterval(() => {
      const moves = ['forward', 'back', 'left', 'right'];
      const dir = moves[Math.floor(Math.random() * moves.length)];
      bot.setControlState(dir, true);
      setTimeout(() => bot.setControlState(dir, false), 500);
      bot.look(Math.random() * Math.PI * 2, (Math.random() - 0.5) * 0.5, false);
    }, CONFIG.behaviors.antiAfkInterval || 30000);
  }

  let autoLookInterval;
  function startAutoLook() {
    clearInterval(autoLookInterval);
    autoLookInterval = setInterval(() => {
      const players = Object.values(bot.players).filter(p => p.entity && p.username !== bot.username);
      if (players.length > 0) bot.lookAt(players[0].entity.position.offset(0, 1.6, 0));
    }, 2000);
  }

  function handleChat(username, message) {
    const owner = CONFIG.bot.owner;
    const isOwner = !owner || username === owner;
    const prefix = CONFIG.bot.commandPrefix || '!';

    if (!message.startsWith(prefix)) {
      if (CONFIG.behaviors.autoRespond) {
        for (const [trigger, response] of Object.entries(CONFIG.behaviors.autoRespond)) {
          if (message.toLowerCase().includes(trigger.toLowerCase())) {
            setTimeout(() => bot.chat(response), 500);
            return;
          }
        }
      }
      return;
    }

    const args = message.slice(prefix.length).trim().split(/\s+/);
    const cmd = args.shift().toLowerCase();

    if (!isOwner && CONFIG.bot.ownerOnly) {
      bot.chat(`Only ${owner} can command me.`);
      return;
    }
    runCommand(cmd, args, username);
  }
}

function runCommand(cmd, args = [], sourceUsername = null) {
  if (!bot || !bot.entity) return 'Bot is not connected.';

  const say = (msg) => { bot.chat(msg); return msg; };

  switch (cmd) {
    case 'come':
    case 'follow': {
      const targetName = sourceUsername || args[0];
      const target = targetName ? bot.players[targetName]?.entity : null;
      if (!target) return say("I can't see that player!");
      bot.pathfinder.setGoal(new goals.GoalFollow(target, 2), true);
      return say(`Following ${targetName}!`);
    }
    case 'stop':
      bot.pathfinder.stop();
      bot.clearControlStates();
      return say('Stopped.');
    case 'goto': {
      const [x, y, z] = args.map(Number);
      if ([x, y, z].some(isNaN)) return 'Usage: goto <x> <y> <z>';
      bot.pathfinder.setGoal(new goals.GoalBlock(x, y, z));
      return say(`Heading to ${x} ${y} ${z}…`);
    }
    case 'say':
      return args.length ? say(args.join(' ')) : 'Nothing to say.';
    case 'pos': {
      const p = bot.entity.position;
      return say(`I'm at ${Math.floor(p.x)}, ${Math.floor(p.y)}, ${Math.floor(p.z)}`);
    }
    case 'health':
      return say(`❤ Health: ${bot.health}/20  🍗 Food: ${bot.food}/20`);
    case 'time':
      return say(`In-game time: ${bot.time.timeOfDay} (day ${bot.time.day})`);
    case 'inventory': {
      const items = bot.inventory.items().map(i => `${i.name}×${i.count}`).join(', ') || 'empty';
      return say(`Inventory: ${items}`);
    }
    case 'look': {
      const [lx, ly, lz] = args.map(Number);
      if ([lx, ly, lz].some(isNaN)) return 'Usage: look <x> <y> <z>';
      bot.lookAt({ x: lx, y: ly, z: lz });
      return `Looking at ${lx} ${ly} ${lz}`;
    }
    case 'jump':
      bot.setControlState('jump', true);
      setTimeout(() => bot.setControlState('jump', false), 500);
      return 'Jumped.';
    case 'sneak':
      bot.setControlState('sneak', !bot.getControlState('sneak'));
      return say(`Sneak: ${bot.getControlState('sneak') ? 'on' : 'off'}`);
    case 'attack': {
      const targetName = args[0];
      const entity = targetName
        ? Object.values(bot.entities).find(e => e.username === targetName || e.name === targetName)
        : bot.nearestEntity();
      if (!entity) return say('No target found.');
      bot.attack(entity);
      return say(`Attacking ${entity.username || entity.name || 'entity'}!`);
    }
    case 'forward':
    case 'back':
    case 'left':
    case 'right':
      bot.pathfinder.stop();
      bot.setControlState(cmd, true);
      setTimeout(() => bot.setControlState(cmd, false), 800);
      return `Moving ${cmd}.`;
    case 'drop': {
      const item = bot.inventory.items()[0];
      if (!item) return 'Nothing to drop.';
      bot.tossStack(item).catch(() => {});
      return say(`Dropped ${item.name}.`);
    }
    case 'disconnect':
      bot.quit();
      return 'Disconnecting…';
    case 'help':
      return say('Commands: come stop goto say pos health inventory attack jump sneak time forward/back/left/right drop');
    default:
      return `Unknown command: ${cmd}`;
  }
}

function tryReconnect() {
  if (reconnectAttempts >= MAX_RECONNECT) {
    if (MAX_RECONNECT > 0) log('Max reconnect attempts reached. Giving up.');
    return;
  }
  reconnectAttempts++;
  const delay = (CONFIG.reconnectDelay || 5) * 1000;
  log(`Reconnecting in ${delay / 1000}s… (attempt ${reconnectAttempts}/${MAX_RECONNECT})`);
  setTimeout(createBot, delay);
}

